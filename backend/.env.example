# =============================================
# BeastMode Backend — Environment Variables
# =============================================
# انسخ هذا الملف وسمّيه .env ثم أضف قيمك الحقيقية

PORT=5000
DATABASE_URL="file:./dev.db"

# مفتاح JWT — ولّد مفتاحاً عشوائياً قوياً:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-strong-random-secret-here"

FRONTEND_URL="http://localhost:5173"

# مفتاح Google Gemini API (من: https://aistudio.google.com)
GEMINI_API_KEY="your-gemini-api-key"

# مفتاح RapidAPI لمكتبة التمارين ExerciseDB (اختياري)
# من: https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb
RAPIDAPI_KEY="your-rapidapi-key"

# مفتاح Groq API — اللغة المستخدمة: LLaMA 3.3 70B
# من: https://console.groq.com
GROQ_API_KEY="your-groq-api-key"
